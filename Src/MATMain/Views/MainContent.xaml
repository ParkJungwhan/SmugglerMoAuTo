<Border xmlns:DetailViews="clr-namespace:MATMain.Views.DetailViews"
    x:Class="MATMain.Views.MainContent" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008" xmlns:hc="https://handyorg.github.io/handycontrol"
    xmlns:local="clr-namespace:MATMain.Views" mc:Ignorable="d" d:DesignHeight="450" d:DesignWidth="800" Effect="{StaticResource EffectShadow4}">
    <hc:SimplePanel>
        <Border Name="BorderRootEffect" Background="{DynamicResource RegionBrush}" CornerRadius="10" Effect="{StaticResource EffectShadow4}" Margin="16" Visibility="Collapsed" />
        <Border Name="BorderRoot" Style="{StaticResource BorderClip}" Margin="16" CornerRadius="10">
            <Grid Name="GridMain" MinHeight="300" MinWidth="200">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition />
                </Grid.RowDefinitions>
                <Border Name="BorderEffect" Grid.RowSpan="2" Background="{DynamicResource RegionBrush}" CornerRadius="10" Effect="{StaticResource EffectShadow4}" />
                <Border Height="32" Name="BorderTitle" Grid.Row="0" CornerRadius="10,10,0,0" Background="{DynamicResource TitleBrush}" Style="{StaticResource BorderClip}">
                    <hc:SimplePanel>
                        <!--<hc:Watermark Mark="{Binding ContentTitle}" MarkMargin="3,0" FontSize="20" FontWeight="Bold" MarkBrush="#0F000000" />-->
                        <TextBlock Style="{StaticResource TextBlockDefault}" Foreground="White" Text="{Binding ContentTitle}" d:Text="Title" />

                        <Button Command="{Binding CmdPlayMacro}" Height="26" Width="30" Margin="6,0,0,0" Padding="5" Foreground="{DynamicResource TextIconBrush}"
                                Style="{StaticResource ButtonIcon}" HorizontalAlignment="Left" hc:IconElement.Geometry="{StaticResource DocumentGeometry}" />
                        <!--<ToggleButton Margin="0,0,6,0" IsChecked="{Binding IsCodeOpened}" Padding="5" Foreground="{DynamicResource TextIconBrush}"
                                      Style="{StaticResource ToggleButtonIconTransparent}" HorizontalAlignment="Right" hc:IconElement.Geometry="{StaticResource CodeGeometry}" />-->
                    </hc:SimplePanel>
                </Border>
                <Border Grid.Row="1" ClipToBounds="True">
                    <hc:TabControl ShowOverflowButton="False" ShowScrollButton="True"  IsScrollable="True">
                        <hc:TabItem Header="TabItem1" IsSelected="True">
                            <hc:SimplePanel Background="{DynamicResource RegionBrush}">
                                <DetailViews:ControllerPageView />
                            </hc:SimplePanel>
                        </hc:TabItem>
                    </hc:TabControl>
                    <!--<ContentPresenter Name="PresenterMain" Margin="0,0,0,10" Content="{Binding SubContent}" />-->
                </Border>
            </Grid>
        </Border>
    </hc:SimplePanel>
</Border>