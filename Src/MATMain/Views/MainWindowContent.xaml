<Border
    x:Class="MATMain.Views.MainWindowContent" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008" xmlns:local="clr-namespace:MATMain.Views"
    mc:Ignorable="d" BorderThickness="0,1,0,0"  xmlns:hc="https://handyorg.github.io/handycontrol" d:Width="800"
    BorderBrush="{DynamicResource BorderBrush}" Background="{StaticResource CloudDrawingBrush}">
    <hc:SimplePanel>
        <Border Name="BorderRootEffect" Background="{DynamicResource RegionBrush}" CornerRadius="10" Effect="{StaticResource EffectShadow4}" Margin="16" Visibility="Collapsed" />
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="ColumnDefinitionLeft" Width="240" MinWidth="240" MaxWidth="400" />
                <ColumnDefinition MinWidth="200" />
            </Grid.ColumnDefinitions>
            <Button x:Name="ButtonShiftOut" Click="OnLeftMainContentShiftOut"
                hc:IconElement.Geometry="{StaticResource LeftGeometry}" Style="{StaticResource ButtonIconCircular}"
                Padding="8 8 0 8" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0 26 -16 0" />
            <local:MainContent Grid.Column="1" x:Name="MainContent" DataContext="{Binding MainModel}" />
            <local:LeftMainContent Grid.Column="0" x:Name="LeftMainContent" DataContext="{Binding LeftModel}">
                <UIElement.RenderTransform>
                    <TranslateTransform />
                </UIElement.RenderTransform>
            </local:LeftMainContent>

            <hc:Drawer Name="DrawerCode" Opened="DrawerCode_OnOpened" Closed="DrawerCode_Closed" IsOpen="{Binding IsCodeOpened}">
                <Border Style="{StaticResource BorderClip}" Margin="32,32,0,32" CornerRadius="10,0,0,10" Background="{DynamicResource RegionBrush}" Width="400">
                    <local:OptionView DataContext="{Binding OptionModel}" />
                </Border>
            </hc:Drawer>
            <GridSplitter x:Name="GridSplitter" Margin="0,26,0,26" Grid.Column="0" HorizontalAlignment="Right" Width="4" Background="Transparent" />
            <Button Grid.Column="0" x:Name="ButtonShiftIn" Visibility="Collapsed" Click="OnLeftMainContentShiftIn"
                hc:IconElement.Geometry="{StaticResource RightGeometry}" Style="{StaticResource ButtonIconCircular}"
                Padding="8 8 0 8" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="-12 26 0 0" />
        </Grid>
    </hc:SimplePanel>
</Border>