<UserControl
    x:Class="MATMain.Views.DetailViews.CaptureView" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008" xmlns:hc="https://handyorg.github.io/handycontrol"
    xmlns:local="clr-namespace:MATMain.Views.DetailViews" mc:Ignorable="d" d:DesignHeight="450" d:DesignWidth="800"
    Focusable="True" Loaded="UserControl_Loaded" PreviewKeyDown="UserControl_PreviewKeyDown">
    <Border Padding="12" Background="{StaticResource RegionBrush}" CornerRadius="12">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition />
                <RowDefinition Height="30" />
            </Grid.RowDefinitions>

            <Border BorderThickness="1" BorderBrush="red" CornerRadius="12">
                <Image Source="{Binding CopyImg}"
                       Stretch="{Binding SelectedStretch}"
                   RenderOptions.BitmapScalingMode="HighQuality" />
                <!--Stretch="Uniform"-->
            </Border>

            <!-- 이미지 없을 때 안내 -->
            <TextBlock Text="Ctrl+V로 이미지 붙여넣기"
                       Foreground="{StaticResource PrimaryTextBrush}"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding CopyImg}" Value="{x:Null}">
                                <Setter Property="Visibility" Value="Visible" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>

            <StackPanel Orientation="Horizontal" Grid.Row="1">
                <ComboBox x:Name="StretchCombo" Height="26" VerticalAlignment="Center"
                  Width="150" SelectedIndex="2"
                  SelectedItem="{Binding SelectedStretch, Mode=TwoWay}">
                    <x:Static Member="Stretch.None" />
                    <x:Static Member="Stretch.Fill" />
                    <x:Static Member="Stretch.Uniform" />
                    <x:Static Member="Stretch.UniformToFill" />
                </ComboBox>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>