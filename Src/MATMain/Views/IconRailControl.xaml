<UserControl
    x:Class="MATMain.Views.IconRailControl" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008" xmlns:local="clr-namespace:MATMain.Views"
    xmlns:converter="clr-namespace:SmugControl.Converters;assembly=SmugControl" xmlns:hc="https://handyorg.github.io/handycontrol"
    mc:Ignorable="d" x:Name="root" d:DesignHeight="300" d:DesignWidth="120">
    <UserControl.Resources>
        <!-- 선택 비교 컨버터 -->
        <converter:SelectedEqualsItemConverter x:Key="SelectedEqualsItemConverter" />
        <converter:NotSelectedFilterConverter x:Key="NotSelectedFilterConverter" />
        <hc:Boolean2VisibilityReConverter x:Key="BooleanToVisibilityConverter" />

        <!-- (이전 답변의 CircleIconButtonStyle / SelectedCircleIconButtonStyle / PlusCircleButtonStyle 그대로 사용)
             여기서는 길어지니 생략. 너가 갖고 있는 스타일 키 그대로 두면 됨 -->
        <Style x:Key="CircleIconButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="92" />
            <Setter Property="Height" Value="92" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <Ellipse x:Name="Ring"
                                     Fill="#2A2F35"
                                     Stroke="#1F2328"
                                     StrokeThickness="4" />
                            <Ellipse Margin="8">
                                <Ellipse.Fill>
                                    <ImageBrush ImageSource="{TemplateBinding Tag}"
                                                Stretch="UniformToFill" />
                                </Ellipse.Fill>
                            </Ellipse>
                            <Ellipse x:Name="Hover"
                                     Fill="#1AFFFFFF"
                                     Opacity="0" />
                        </Grid>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Hover" Property="Opacity" Value="1" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Hover" Property="Fill" Value="#2AFFFFFF" />
                                <Setter TargetName="Hover" Property="Opacity" Value="1" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Hover" Property="Fill" Value="#66000000" />
                                <Setter TargetName="Hover" Property="Opacity" Value="1" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 선택 강조(링 Stroke만 하이라이트) -->
        <Style x:Key="SelectedCircleIconButtonStyle" TargetType="Button" BasedOn="{StaticResource CircleIconButtonStyle}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <Ellipse Fill="#2A2F35"
                                     Stroke="#EAF1FB"
                                     StrokeThickness="6" />
                            <Ellipse Margin="8">
                                <Ellipse.Fill>
                                    <ImageBrush ImageSource="{TemplateBinding Tag}"
                                                Stretch="UniformToFill" />
                                </Ellipse.Fill>
                            </Ellipse>
                            <Ellipse x:Name="Hover"
                                     Fill="#1AFFFFFF"
                                     Opacity="0" />
                        </Grid>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Hover" Property="Opacity" Value="1" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Hover" Property="Fill" Value="#2AFFFFFF" />
                                <Setter TargetName="Hover" Property="Opacity" Value="1" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- + 버튼 -->
        <Style x:Key="PlusCircleButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="110" />
            <Setter Property="Height" Value="110" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <Ellipse Fill="#0F1318" Stroke="#0B2E3A" StrokeThickness="6" />
                            <TextBlock Text="+"
                                       Foreground="#EAF1FB"
                                       FontSize="56"
                                       FontWeight="SemiBold"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       Margin="0,-6,0,0" />
                            <Ellipse x:Name="Hover" Fill="#1AFFFFFF" Opacity="0" />
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Hover" Property="Opacity" Value="1" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Hover" Property="Fill" Value="#2AFFFFFF" />
                                <Setter TargetName="Hover" Property="Opacity" Value="1" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Border Background="#17647A" Padding="14">
        <DockPanel LastChildFill="True">

            <!-- 맨 아래 + 버튼 (항상 고정) -->
            <Button DockPanel.Dock="Bottom"
                    Style="{StaticResource PlusCircleButtonStyle}"
                    Margin="0,18,0,0"
                    Command="{Binding ElementName=root, Path=AddCommand}" />

            <!-- 선택 슬롯 (아래에 고정, 아이템 없으면 숨김) -->
            <Button DockPanel.Dock="Bottom"
                    Style="{StaticResource SelectedCircleIconButtonStyle}"
                    Margin="0,6,0,0"
                    Tag="{Binding ElementName=root, Path=SelectedIconSource}"
                    Command="{Binding ElementName=root, Path=ItemClickCommand}"
                    CommandParameter="{Binding ElementName=root, Path=SelectedItem}"
                    Visibility="{Binding ElementName=root, Path=HasItems, Converter={StaticResource BooleanToVisibilityConverter}}" />

            <!-- 스크롤 아이템 리스트 (위쪽 전체) -->
            <ScrollViewer VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <ItemsControl>
                    <ItemsControl.ItemsSource>
                        <MultiBinding Converter="{StaticResource NotSelectedFilterConverter}">
                            <Binding ElementName="root" Path="ItemsSource" />
                            <Binding ElementName="root" Path="SelectedItem" />
                        </MultiBinding>
                    </ItemsControl.ItemsSource>

                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Vertical" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>

                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Button Style="{StaticResource CircleIconButtonStyle}"
                                    Margin="0,10,0,10"
                                    Tag="{Binding Icon}"
                                    Command="{Binding ElementName=root, Path=ItemClickCommand}"
                                    CommandParameter="{Binding}" />
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </DockPanel>
    </Border>
</UserControl>