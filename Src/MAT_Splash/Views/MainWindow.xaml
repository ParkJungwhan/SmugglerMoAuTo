<Window
    x:Class="MainAppSplash.Views.MainWindow" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" xmlns:local="clr-namespace:MainAppSplash"
    mc:Ignorable="d" Title="{Binding Title}" Height="600" Width="400" WindowStyle="None" WindowStartupLocation="CenterScreen"
    ResizeMode="NoResize" AllowsTransparency="True" Background="Transparent" ShowInTaskbar="False" Topmost="True">

    <!-- Outer shadow + rounded -->
    <Border CornerRadius="18"
            SnapsToDevicePixels="True">
        <Border.Effect>
            <DropShadowEffect BlurRadius="24" ShadowDepth="0" Opacity="0.35" />
        </Border.Effect>

        <!-- Background -->
        <Border CornerRadius="18" Padding="20">
            <Border.Background>
                <!-- 단일 톤 기반 + 살짝 그라데이션 -->
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="#151A20" Offset="0" />
                    <GradientStop Color="#101419" Offset="1" />
                </LinearGradientBrush>
            </Border.Background>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="160" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Button Width="32"
        Height="32"
        HorizontalAlignment="Right"
        VerticalAlignment="Top"
        Margin="0"
        Click="CloseButton_Click"
        Background="Transparent"
        BorderThickness="0"
        Cursor="Hand">

                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="bd"
                    CornerRadius="6"
                    Background="Transparent">
                                <TextBlock Text="✕"
                           FontSize="14"
                           FontWeight="SemiBold"
                           Foreground="#9AA6B5"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center" />
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="bd" Property="Background" Value="#1F2730" />
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="bd" Property="Background" Value="#2A333D" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <!-- Top / Center branding -->
                <StackPanel Grid.Row="0" VerticalAlignment="Center" HorizontalAlignment="Center" Margin="0,10,0,0">
                    <!-- MAT (각 글자 하이라이트) -->
                    <TextBlock FontSize="86"
                               FontWeight="SemiBold"
                               FontFamily="Segoe UI"
                               TextAlignment="Center"
                               Margin="0,0,0,6">
                        <Run Text="M" Foreground="#DDE6F0" />
                        <Run Text="A" Foreground="#BFD0E3" />
                        <Run Text="T" Foreground="#E9F1FB" />
                    </TextBlock>

                    <!-- Subtitle -->
                    <TextBlock Text="Mobile AuTo"
                               FontSize="16"
                               FontWeight="Light"
                               Foreground="#AAB6C4"
                               HorizontalAlignment="Center"
                               Opacity="0.95" />

                    <!-- 아주 약한 라인 포인트 (과한 화려함 X) -->
                    <Border Width="220" Height="2" Margin="0,18,0,0" CornerRadius="1">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="#00000000" Offset="0" />
                                <GradientStop Color="#40AAB6C4" Offset="0.5" />
                                <GradientStop Color="#00000000" Offset="1" />
                            </LinearGradientBrush>
                        </Border.Background>
                    </Border>
                </StackPanel>

                <!-- Log view -->
                <Border Grid.Row="1"
                        CornerRadius="12"
                        BorderBrush="#2A313A"
                        BorderThickness="1"
                        Padding="10"
                        Background="#0F1318">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <TextBlock Text="App Start..."
                                   FontSize="12"
                                   Foreground="#8FA0B3"
                                   Margin="2,0,0,8" />

                        <!-- 스크롤 로그 -->
                        <ScrollViewer Grid.Row="1"
                                      VerticalScrollBarVisibility="Hidden"
                                      HorizontalScrollBarVisibility="Disabled">
                            <ItemsControl ItemsSource="{Binding Logs}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding}"
                                                   FontSize="12"
                                                   Foreground="#C6D0DB"
                                                   Opacity="0.95"
                                                   Margin="2,2,2,2" />
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>

                        <!-- 위쪽 페이드(스크롤 느낌 강화) -->
                        <Rectangle VerticalAlignment="Top" Height="18" IsHitTestVisible="False">
                            <Rectangle.Fill>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                    <GradientStop Color="#0F1318" Offset="0" />
                                    <GradientStop Color="#000F1318" Offset="1" />
                                </LinearGradientBrush>
                            </Rectangle.Fill>
                        </Rectangle>

                        <!-- 아래쪽 페이드 -->
                        <Rectangle VerticalAlignment="Bottom" Height="18" IsHitTestVisible="False">
                            <Rectangle.Fill>
                                <LinearGradientBrush StartPoint="0,1" EndPoint="0,0">
                                    <GradientStop Color="#0F1318" Offset="0" />
                                    <GradientStop Color="#000F1318" Offset="1" />
                                </LinearGradientBrush>
                            </Rectangle.Fill>
                        </Rectangle>
                    </Grid>
                </Border>

                <!-- Version bottom -->
                <TextBlock Grid.Row="2"
                           Text="{Binding VersionText}"
                           FontSize="12"
                           Foreground="#8B98A7"
                           HorizontalAlignment="Center"
                           Margin="0,14,0,0"
                           Opacity="0.95" />
            </Grid>
        </Border>
    </Border>
</Window>